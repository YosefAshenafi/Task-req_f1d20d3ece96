<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="unit_tests/bootstrap.php"
         cacheDirectory=".phpunit.cache"
         executionOrder="defects"
         failOnRisky="false"
         failOnWarning="false"
>
    <!--
        Tests use SQLite in-memory via unit_tests/bootstrap.php; no host-side
        DB vars are needed. The <php><env> block that previously lived here was
        dead configuration and has been removed to avoid misleading contributors.
    -->
    <testsuites>
        <testsuite name="unit">
            <directory>unit_tests</directory>
        </testsuite>
        <testsuite name="api">
            <directory>API_tests</directory>
        </testsuite>
        <testsuite name="e2e">
            <directory>e2e_tests</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory suffix=".php">backend/app/</directory>
        </include>
    </source>
</phpunit>